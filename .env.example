TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
PUBLICMETADB_API_KEY=pm-
MDBLIST_API_KEY=

# Optional
TRAKT_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
POLL_INTERVAL_SECONDS=60
HISTORY_OVERLAP_MINUTES=10
RECONCILE_INTERVAL_HOURS=24
TRAKT_PAGE_LIMIT=100
DATABASE_PATH=/data/sync.db
PORT=3000
RUN_BACKFILL_ON_START=true
MDBLIST_WATCHLIST_SYNC_ENABLED=false
MDBLIST_WATCHLIST_POLL_INTERVAL_SECONDS=3600
LOG_FORMAT=text

# Useful for tests or self-hosting proxies.
# TRAKT_BASE_URL=https://api.trakt.tv
# PUBLICMETADB_BASE_URL=https://publicmetadb.com
# MDBLIST_BASE_URL=https://api.mdblist.com
